{
  "slug": "company-hiring-signals",
  "username": "oblanceolate_mandola",
  "title": "Company Hiring Signals — Job Postings to JSON",
  "shortDescription": "Scrape job postings from any company on Greenhouse, Lever or Ashby by company name — hiring signals as clean JSON at $0.002 per posting.",
  "seoTitle": "Job Postings Scraper — Company Hiring Signals to JSON (Greenhouse, Lever, Ashby)",
  "seoDescription": "Hiring signals & job postings API: scrape live jobs from Greenhouse, Lever and Ashby by company name as JSON. For sales-intel AI agents. Pay per result.",
  "categories": [
    "JOBS",
    "BUSINESS",
    "AUTOMATION"
  ],
  "viewFields": [
    "query",
    "title",
    "department",
    "location",
    "remote",
    "postedAt",
    "url"
  ],
  "pricing": {
    "pricePerResultUsd": 0.002
  },
  "sourceMode": "firstHit",
  "defaults": {
    "maxResults": 1000
  },
  "query": {
    "label": "Company",
    "description": "Company slug as used on its job board, e.g. \"stripe\" (boards.greenhouse.io/stripe), \"palantir\" (jobs.lever.co/palantir), \"openai\" (jobs.ashbyhq.com/openai). Case-insensitive; must be the URL identifier, not the display name (\"Stripe, Inc.\" will not match).",
    "example": "stripe",
    "prefill": [
      "stripe",
      "openai",
      "palantir"
    ],
    "normalize": "slug"
  },
  "readme": {
    "intro": "A company opening new roles is a buying signal: budget exists, growth is happening, tools are being bought. This actor turns any company name into its live job postings — normalized across the three most common tech ATS platforms (Greenhouse, Lever, Ashby) — so sales-intelligence agents, recruiting agents and research pipelines can read hiring activity as structured data. It reads each platform's public job-board API directly: no browser, no proxies, no scraping fragility, results in seconds.",
    "bullets": [
      "Look up live job postings for any company hosted on Greenhouse, Lever or Ashby — auto-detected, one unified output shape",
      "Hiring-signal fields: title, department, team, location(s), remote flag, employment type, compensation (when published), posted date",
      "Filter by keywords, location, remote-only, or postedAfter for incremental scheduled runs (only new postings since last run)",
      "Batch many companies in one run; cap spend with maxResults",
      "Built for agents: flat JSON, sourceUrl + scrapedAt on every item for citation, callable via MCP and the Apify API"
    ],
    "sampleOutput": {
      "query": "stripe",
      "source": "greenhouse",
      "title": "Account Executive, AI Sales",
      "department": "Sales",
      "team": null,
      "location": "San Francisco, CA",
      "locations": null,
      "remote": false,
      "employmentType": null,
      "compensation": null,
      "postedAt": "2026-06-02T14:01:00.000Z",
      "url": "https://stripe.com/jobs/search?gh_jid=7964697",
      "sourceUrl": "https://boards-api.greenhouse.io/v1/boards/stripe/jobs",
      "scrapedAt": "2026-06-10T15:00:00.000Z"
    },
    "faq": [
      {
        "q": "How do I find a company's slug?",
        "a": "Use the identifier in its job-board URL: boards.greenhouse.io/**stripe**, jobs.lever.co/**palantir**, jobs.ashbyhq.com/**openai**. Pass that word as the query. The actor auto-detects which of the three platforms the company uses."
      },
      {
        "q": "What if a company is not on Greenhouse, Lever, or Ashby?",
        "a": "You get zero results for that company and are charged nothing. Many large enterprises use Workday or Taleo, which this actor does not cover in v1."
      },
      {
        "q": "How do I get only new postings since my last run?",
        "a": "Set postedAfter to your last run date (e.g. 2026-06-01). Combined with a scheduled run, this gives you an incremental hiring-signal feed."
      },
      {
        "q": "Do I pay for companies that return no jobs?",
        "a": "No. You only pay for successful results — one charge per job posting actually returned."
      }
    ]
  },
  "sources": [
    {
      "id": "greenhouse",
      "urlTemplate": "https://boards-api.greenhouse.io/v1/boards/{query}/jobs",
      "descriptionParam": "?content=true",
      "itemsPath": "jobs",
      "fields": {
        "jobId": {
          "path": "id",
          "transform": "toString"
        },
        "title": "title",
        "department": "departments.0.name",
        "team": {
          "path": "metadata.team",
          "optional": true
        },
        "location": "location.name",
        "remote": {
          "path": "location.name",
          "transform": "boolRemote"
        },
        "employmentType": {
          "path": "metadata.employment_type",
          "optional": true
        },
        "compensation": {
          "path": "metadata.compensation",
          "optional": true
        },
        "postedAt": {
          "path": "first_published",
          "transform": "toIso"
        },
        "updatedAt": {
          "path": "updated_at",
          "transform": "toIso"
        },
        "url": "absolute_url",
        "description": {
          "path": "content",
          "transform": "stripHtml"
        }
      }
    },
    {
      "id": "lever",
      "urlTemplate": "https://api.lever.co/v0/postings/{query}?mode=json",
      "itemsPath": "",
      "fields": {
        "jobId": "id",
        "title": "text",
        "department": {
          "path": "categories.department",
          "optional": true
        },
        "team": {
          "path": "categories.team",
          "optional": true
        },
        "location": "categories.location",
        "remote": {
          "path": "workplaceType",
          "transform": "boolRemote"
        },
        "employmentType": "categories.commitment",
        "compensation": {
          "path": "salaryRange.max",
          "optional": true
        },
        "postedAt": {
          "path": "createdAt",
          "transform": "toIso"
        },
        "url": "hostedUrl",
        "description": {
          "path": "descriptionPlain",
          "transform": "trim"
        }
      }
    },
    {
      "id": "ashby",
      "urlTemplate": "https://api.ashbyhq.com/posting-api/job-board/{query}?includeCompensation=true",
      "itemsPath": "jobs",
      "fields": {
        "jobId": "id",
        "title": "title",
        "department": "department",
        "team": {
          "path": "team",
          "optional": true
        },
        "location": "location",
        "remote": "isRemote",
        "employmentType": "employmentType",
        "compensation": {
          "path": "compensation.compensationTierSummary",
          "optional": true
        },
        "postedAt": {
          "path": "publishedAt",
          "transform": "toIso"
        },
        "url": "jobUrl",
        "description": {
          "path": "descriptionPlain",
          "transform": "trim"
        }
      }
    }
  ],
